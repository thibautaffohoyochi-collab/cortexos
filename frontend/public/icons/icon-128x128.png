<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <!-- Background -->
  <rect width="512" height="512" rx="80" fill="#030712"/>
  <!-- Gradient definition -->
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#2563eb;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#7c3aed;stop-opacity:1" />
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="8" result="blur"/>
      <feComposite in="SourceGraphic" in2="blur" operator="over"/>
    </filter>
  </defs>
  <!-- Hexagon ⬡ shape -->
  <polygon
    points="256,80 380,148 380,284 256,352 132,284 132,148"
    fill="url(#grad)"
    filter="url(#glow)"
    opacity="0.15"
  />
  <polygon
    points="256,100 365,160 365,280 256,340 147,280 147,160"
    fill="none"
    stroke="url(#grad)"
    stroke-width="8"
  />
  <!-- Inner hexagon -->
  <polygon
    points="256,155 310,185 310,245 256,275 202,245 202,185"
    fill="url(#grad)"
  />
  <!-- Center text -->
  <text
    x="256" y="238"
    font-family="system-ui, sans-serif"
    font-size="60"
    font-weight="900"
    text-anchor="middle"
    dominant-baseline="middle"
    fill="white"
  >C</text>
  <!-- Bottom text -->
  <text
    x="256" y="410"
    font-family="system-ui, sans-serif"
    font-size="36"
    font-weight="600"
    text-anchor="middle"
    fill="#94a3b8"
    letter-spacing="8"
  >CORTEX</text>
</svg>
